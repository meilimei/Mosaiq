{
  "name": "@mosaiq/cli",
  "version": "0.10.0",
  "description": "Mosaiq CLI — run Detection Lab and manage personas from the terminal",
  "license": "Apache-2.0",
  "homepage": "https://github.com/meilimei/Mosaiq/tree/main/packages/cli#readme",
  "bugs": { "url": "https://github.com/meilimei/Mosaiq/issues" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meilimei/Mosaiq.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "mosaiq",
    "antidetect",
    "anti-detect",
    "fingerprint",
    "browser-fingerprint",
    "persona",
    "playwright",
    "automation",
    "anti-bot",
    "cli",
    "detection-lab",
    "stealth"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "type": "module",
  "bin": {
    "mosaiq": "./bin/mosaiq.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist", "bin", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist",
    "start": "tsx src/cli.ts"
  },
  "dependencies": {
    "@runova/persona-schema": "workspace:*",
    "@runova/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
