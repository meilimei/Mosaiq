{
  "name": "@mosaiq/cli",
  "version": "0.9.0",
  "description": "Mosaiq CLI — run Detection Lab and manage personas from the terminal",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "bin": {
    "mosaiq": "./bin/mosaiq.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist", "bin", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist",
    "start": "tsx src/cli.ts"
  },
  "dependencies": {
    "@mosaiq/persona-schema": "workspace:*",
    "@mosaiq/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
