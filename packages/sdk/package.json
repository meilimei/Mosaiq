{
  "name": "@runova/sdk",
  "version": "0.10.1",
  "description": "Mosaiq SDK — launch Chromium with persona-driven anti-detection. Drop-in for Playwright/Stagehand.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/meilimei/Mosaiq/tree/main/packages/sdk#readme",
  "bugs": { "url": "https://github.com/meilimei/Mosaiq/issues" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meilimei/Mosaiq.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "mosaiq",
    "antidetect",
    "anti-detect",
    "fingerprint",
    "browser-fingerprint",
    "persona",
    "playwright",
    "playwright-core",
    "playwright-extra",
    "stagehand",
    "puppeteer-extra",
    "stealth",
    "rebrowser-patches",
    "automation",
    "anti-bot",
    "cdp",
    "detection-lab"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./injection": {
      "types": "./dist/injection/index.d.ts",
      "import": "./dist/injection/index.js"
    }
  },
  "files": ["dist", "patches", "scripts", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "postinstall": "node ./scripts/postinstall.cjs",
    "demo:humanize": "tsx examples/humanize-demo.ts",
    "bench": "tsx bench/baseline-detection.ts",
    "bench:report": "tsx bench/report.ts",
    "bench:all": "pnpm bench && pnpm bench:report",
    "bench:canvas": "tsx bench/canvas-cross-check.ts",
    "bench:verify-creepjs": "tsx bench/verify-creepjs-profile-hash.ts",
    "bench:convert-profile": "tsx bench/convert-captured-profile.ts",
    "bench:integrate-profiles": "tsx bench/integrate-captured-profiles.ts",
    "bench:capture-self": "tsx bench/capture-self-webgl-profile.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@runova/persona-schema": "workspace:*",
    "https-proxy-agent": "^7.0.6",
    "patch-package": "^8.0.0",
    "playwright-core": "1.59.1",
    "socks-proxy-agent": "^8.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "happy-dom": "^15.11.7",
    "playwright": "1.59.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
