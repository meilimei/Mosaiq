# Mosaiq Browser Pod — env vars
# 单 session pod 用。一个 pod 一次只跑一个 chromium 进程。

# ─── 控制端口 ───
POD_CONTROL_PORT=9222
POD_CONTROL_HOST=0.0.0.0

# ─── chromium 端口 / 数据 ───
# remote-debugging-port: chromium 暴露的 CDP 端口 (HTTP + WS)
POD_CDP_PORT=9223
# user-data-dir: chromium 持久化（cookie/IndexedDB/Service Worker）
POD_PROFILE_DIR=./data/profile

# ─── chromium binary ───
# 优先使用此 env 指向的二进制；为空则用 playwright-core 默认下载位置
POD_CHROME_EXECUTABLE=
# 默认 headless=new。dev 想看真实窗口可以改 false。
POD_HEADLESS=true

# ─── 日志 ───
LOG_LEVEL=info

# ─── chromium 启动超时 ───
POD_CHROMIUM_BOOT_TIMEOUT_MS=30000
