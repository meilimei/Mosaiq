# Mosaiq Cloud Runtime — env vars
# 复制为 .env 后修改本地值；prod 在 Fly secrets 里设。

# ─── 服务监听 ───
PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info               # debug | info | warn | error

# ─── 数据库 ───
# dev 默认 sqlite 文件；prod 设 DATABASE_URL=postgres://...
DATABASE_URL=sqlite:./data/cloud-runtime.db

# ─── 机器后端选型 ───
# static       —— phase 11.1 默认。预先存在的 pod 池，POD_ADDRS 列出地址
# local-docker —— phase 11.1 玩具：本地 docker socket 即时拉起 pod
# fly          —— phase 11.2 实现：Fly Machines API
MACHINE_MANAGER=static
# 仅当 MACHINE_MANAGER=static 时使用，逗号分隔的 pod 内部地址
POD_ADDRS=http://browser-pod-1:9222,http://browser-pod-2:9222

# 仅当 MACHINE_MANAGER=local-docker 时
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_IMAGE=mosaiq/browser-pod:0.11.0

# 仅当 MACHINE_MANAGER=fly 时
FLY_API_TOKEN=
FLY_APP_NAME=mosaiq-browser-pod
FLY_REGION=iad

# ─── 认证（dev 种子 key）───
# 启动时如果 DB 里没有 api_keys，会自动 seed 一个，使用下面的 plaintext
# 注意 prod 必须留空，prod 走 admin CLI 创建 key
SEED_PROJECT_ID=proj_launchai
SEED_API_KEY=msq_sk_dev_seed_change_me_in_prod_xxxxxxxxxxxx

# ─── session 默认值 ───
SESSION_TTL_DEFAULT_SECONDS=1800
SESSION_TTL_MAX_SECONDS=7200

# ─── 控制平面对外公开的 base URL，用于 cdp_url 拼接 ───
# dev: http://localhost:8787
# prod: https://api.mosaiq.dev
PUBLIC_BASE_URL=http://localhost:8787
