{
  "name": "@mosaiq/cloud-runtime",
  "version": "0.11.0",
  "description": "Mosaiq Cloud Runtime — control plane (Hono on Node, Fly.io ready). REST + CDP-over-WebSocket gateway for the per-session browser pool.",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=20.10.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mosaiq-cloud-runtime": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "seed": "tsx src/db/seed.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@mosaiq/persona-schema": "workspace:*",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.12",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "undici": "^7.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.7.5",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
