{
  "name": "mosaiq",
  "version": "0.1.0",
  "private": true,
  "description": "Mosaiq — Browser infrastructure for the agentic AI economy",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meilimei/Mosaiq.git"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "build:all": "pnpm -r run build",
    "dev:desktop": "pnpm --filter @mosaiq/desktop dev",
    "mosaiq": "tsx packages/cli/src/cli.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "check-sdk-patch-drift": "node scripts/check-sdk-patch-drift.mjs",
    "audit-tarballs": "node scripts/audit-tarballs.mjs",
    "build-fixture-personas": "tsx scripts/build-fixture-personas.ts",
    "ci-compare-baseline": "node scripts/ci-compare-baseline.mjs",
    "clean": "pnpm -r run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.31.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "patchedDependencies": {
      "playwright-core@1.59.1": "patches/playwright-core@1.59.1.patch"
    }
  }
}
