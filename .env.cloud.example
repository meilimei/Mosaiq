# 给 docker-compose -f docker-compose.cloud.yml 用的环境变量。
# 复制成 .env.cloud（已被 .gitignore），改 SEED_API_KEY 为你自己用的。

SEED_PROJECT_ID=proj_launchai

# 32+ 字符随机串。LaunchAI 把它放 .env.local 的 MOSAIQ_API_KEY。
# Linux/macOS 生成：
#   echo "msq_sk_dev_seed_$(openssl rand -hex 12)"
# Windows PowerShell：
#   "msq_sk_dev_seed_$(-join ((48..57)+(97..122) | Get-Random -Count 24 | %{[char]$_}))"
SEED_API_KEY=msq_sk_dev_seed_change_me_in_prod_xxxxxxxxxxxx

# MOSAIQ_METRICS_TOKEN：开启 GET /v1/metrics (Prometheus exposition)。
# - 留空 / 不设：endpoint 返 404（disabled）。dev-local-docker-smoke.mjs 仍会
#   验证 404 行为。
# - 设值：cloud-runtime 把它写入 METRICS_TOKEN env，scraper 用
#   `Authorization: Bearer <value>` 拉。dev-local-docker-smoke.mjs 会断言
#   401 unauth + 200 + body 含 sessions_created_total / http_request_duration_seconds。
# 跟 SEED_API_KEY 一样的生成方式：
#   echo "msq_metrics_$(openssl rand -hex 12)"
# MOSAIQ_METRICS_TOKEN=msq_metrics_change_me_in_prod_xxxxxxxxxxxx
